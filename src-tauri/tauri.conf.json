{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/.schema/config.schema.json",
  "productName": "Translate",
  "version": "0.2.0",
  "identifier": "com.lish.translate",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Translate",
        "width": 620,
        "height": 380,
        "minWidth": 480,
        "minHeight": 280,
        "center": true,
        "alwaysOnTop": true,
        "resizable": true,
        "decorations": false,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
